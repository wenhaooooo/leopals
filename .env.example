# Application Settings
APP_NAME=LeoPals
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# LLM Settings
OPENAI_API_KEY=your-deepseek-or-openai-api-key
OPENAI_API_BASE=https://api.deepseek.com/v1
LLM_MODEL_NAME=deepseek-chat
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Embedding Settings
EMBEDDING_MODEL_NAME=nomic-embed-text:v1.5
EMBEDDING_DIMENSION=768

# PostgreSQL (pgvector) Settings
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=leopals
DATABASE_URL=postgresql+asyncpg://postgres:your-postgres-password@localhost:5432/leopals

# Ollama Settings
OLLAMA_HOST=http://localhost:11434

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Logging Settings
LOG_LEVEL=INFO
LOG_FORMAT=json